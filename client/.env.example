# Public API base URL (no secrets). Used by the Vite client as VITE_*.

# Local dev: leave empty so fetches use relative URLs like /api/... — Vite proxies /api to
# http://localhost:3000 (see vite.config.js). Run the server in ../server on port 3000.
VITE_API_URL=

# Optional: call the API directly instead of the proxy (must match server URL and CORS).
# VITE_API_URL=http://localhost:3000

# Production build: set to your deployed API origin (public URL, not a secret).
# VITE_API_URL=https://your-api.example.com
